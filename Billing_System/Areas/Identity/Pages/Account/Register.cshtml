@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row">
    <div class="col-md-4 shadow-lg" style="padding: 30px">
        <section class="shadow-sm shadow-lg" style="padding: 30px">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
          
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-floating" style="padding-bottom: 5px">
                <input asp-for="Input.UserName" class="form-control" autocomplete="username" aria-required="true" />
                <label asp-for="Input.UserName"></label>
                <span asp-validation-for="Input.UserName" class="text-danger"></span>
            </div>
            <div class="form-floating" style="padding-bottom: 5px">
                <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" />
                <label asp-for="Input.Email"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="form-floating" style="padding-bottom: 5px">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" />
                <label asp-for="Input.Password"></label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="form-floating" style="padding-bottom: 5px">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" />
                <label asp-for="Input.ConfirmPassword"></label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
                <button id="registerSubmit" type="submit" class="btn btn-outline-primary">Register</button>
        </form>
</section>
    </div>
    <div class="col-md-8 col-md-offset-2">
        <section>
            <h3 class="shadow-sm shadow-lg">INFOCAST STSYSTEMS-BILLING</h3>
            <hr />
            <img src="~/system.png" class="img-fluid" alt="Responsive image">
        </section>
    </div>
   
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
