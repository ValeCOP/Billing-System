@model AddTechProblemView
@{
    ViewData["Title"] = "Add";
}

<h2><i class="fa-solid fa-triangle-exclamation"></i> Add TechProblem</h2>
<div class="shadow-lg" style="padding: 30px">
    <hr />
    <div class="row shadow-lg">
        <div class="shadow-lg col-md-4 p-3" style="padding: 30px">
        <h4>Report a problem</h4>
        <hr />
            <form asp-action="Add">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <label asp-for="ClientId" class="control-label"></label>
                    <select asp-for="ClientId" class="form-control" onchange="makeCardTechProblem(@JsonConvert.SerializeObject(Model.Clients))">
                        <option value="">--Please choose Client--</option>
                        @foreach (var client in Model.Clients)
                        {
                            <option value="@client.Id">@client.FullName</option>
                        }
                    </select>
                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Description" class="control-label"></label>
                    <textarea asp-for="Description" class="form-control" id="Description"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="RegisteredOn" class="control-label"></label>
                    <input asp-for="RegisteredOn" class="form-control" type="test" value="@DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)" readonly />
                    <span asp-validation-for="RegisteredOn" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <input asp-for="RegisterProblemUserId" class="form-control" hidden />
                </div>
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary mt-2" />
                </div>
            </form>
        </div>
        <div class="col-md-8 shadow-lg p-3">
            <h4>Client info</h4>
            <hr />
            <div id="demoCard" hidden></div>
            <div id="demoDesc" hidden></div>
           
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
