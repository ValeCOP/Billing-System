@model ResolveTechProblem

@{
    ViewData["Title"] = "Resolve - TechProblem";
}

<h2><i class="fa-solid fa-triangle-exclamation"></i> Solve TechProblem</h2>
<div class="shadow-lg" style="padding: 30px">
    <hr />
    <div class="row shadow-lg">
        <div class="shadow-lg col-md-4 p-3">
            <h4>Solve problem</h4>
            <hr />
            <form asp-action="Resolve">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <label asp-for="Description" class="control-label"></label>
                    <textarea asp-for="Description" class="form-control" id="Description"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="RegisteredOn" class="control-label"></label>
                    <input asp-for="RegisteredOn" class="form-control" type="test" value="@DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)" readonly />
                    <span asp-validation-for="RegisteredOn" class="text-danger"></span>
                </div>
                <div class="form-group form-check">
                    <label class="form-check-label">
                        <input class="form-check-input" asp-for="Solved" checked hidden />
                    </label>
                </div>
                <div class="form-group">
                    <input type="submit" value="Resolve" class="btn btn-outline-primary mt-2" />
                </div>
            </form>
        </div>
        <div class="col-md-8 shadow-lg p-3">
            <h4>Problem info</h4>
            <hr />
            <div>
                <dl class="row">
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.Description)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.Description)
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.RegisteredOn)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.RegisteredOn)
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.ClientName)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.ClientName)
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.ClientEmail)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.ClientEmail)
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.ClientPhone)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.ClientPhone)
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.ClientAddress)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.ClientAddress)
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.RegisterProblemUserName)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.RegisterProblemUserName)
                    </dd>
                </dl>
                <hr />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
